# ────────────────────────────────────────────────
# REMAX De Woonspecialist — Omgevingsvariabelen
# ────────────────────────────────────────────────
# Kopieer dit bestand naar .env en vul je gegevens in.
# Het .env bestand mag NOOIT op GitHub worden gezet!

# Notion Integration Token
# Aanmaken via: https://www.notion.so/my-integrations
# Klik op "+ New integration" → geef het een naam (bijv. "Woonspecialist Website")
# → kopieer de "Internal Integration Token" hieronder
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Notion Database ID (al ingevuld — jouw Leads database)
NOTION_DATABASE_ID=4bb8bddd-2ddf-445d-ac12-1d14ba3d109b

# Poort waarop de server draait (standaard 3000)
PORT=3000
